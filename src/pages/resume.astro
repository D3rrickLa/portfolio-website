---
// src/pages/resume.astro
import Layout from "../layouts/Layout.astro";
import { getEntry, render } from "astro:content";

// Fetch the resume markdown file
const entry = await getEntry("resume", "derrick");

if (!entry) {
  return Astro.redirect("/404");
}

const { name, location, email, linkedin, github } = entry.data;

// Use the modern render function passing the entry object
const { Content } = await render(entry);
---

<Layout title={`${name} | Resume`}>
  <!-- 
    Centering Wrapper:
    Using flex items-center justify-center pulls your card 
    into the exact center of the page.
  -->
  <div
    class="min-h-screen w-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8"
  >
    <!-- Styled Resume Card -->
    <div
      class="max-w-4xl w-full bg-white dark:bg-slate-900 shadow-2xl rounded-2xl border border-slate-200/60 dark:border-slate-800/80 overflow-hidden transition-shadow duration-300 hover:shadow-2xl"
    >
      <!-- Top Action Bar -->
      <div
        class="bg-slate-950 px-6 sm:px-8 py-4 flex flex-row justify-between items-center gap-4 border-b border-slate-800"
      >
        <div class="flex items-center">
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-xs sm:text-sm font-semibold transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
              stroke="currentColor"
              class="w-3.5 h-3.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
            </svg>
            Back to Home
          </a>
        </div>
        <a
          href="/documents/resume.pdf"
          download="Derrick_La_Resume.pdf"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 active:scale-[0.98] text-white font-semibold px-4 py-2 rounded-lg text-sm transition-all duration-200 shadow-sm"
        >
          <!-- Fixed SVG Size -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-4 h-4 flex-shrink-0"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
            ></path>
          </svg>
          <span class="hidden sm:inline">Download PDF</span>
        </a>
      </div>

      <!-- Main Resume Container -->
      <main class="p-8 sm:p-12 text-slate-800 dark:text-slate-200">
        <!-- Header pulled from frontmatter -->
        <header
          class="border-b border-slate-200 dark:border-slate-800 pb-6 text-center sm:text-left mb-8"
        >
          <h1
            class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight sm:text-5xl"
          >
            {name}
          </h1>
          <p
            class="text-lg text-slate-600 dark:text-slate-400 font-medium mt-2"
          >
            {location}
          </p>

          <div
            class="mt-4 flex flex-wrap justify-center sm:justify-start gap-y-2 gap-x-4 text-sm text-slate-500 dark:text-slate-400"
          >
            <a
              href={`mailto:${email}`}
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center gap-1.5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-4 h-4 text-slate-400"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H4.5a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5H4.5a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                ></path>
              </svg>
              {email}
            </a>
            <span class="hidden sm:inline text-slate-300 dark:text-slate-700"
              >|</span
            >
            <a
              href={linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              LinkedIn
            </a>
            <span class="hidden sm:inline text-slate-300 dark:text-slate-700"
              >|</span
            >
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              GitHub
            </a>
          </div>
        </header>

        <!-- Zero-Dependency Styled Markdown Body -->
        <div class="resume-content">
          <Content />
        </div>
      </main>
    </div>
  </div>
</Layout>

<style is:global>
  /* Tells Tailwind v4 to load the utility dictionary for @apply */
  @reference "tailwindcss";

  /* 1. Category Headers */
  .resume-content h2 {
    @apply text-lg sm:text-xl font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400 border-b-2 border-blue-500/10 pb-1 mt-8 mb-4;
  }
  .resume-content h2 {
    @apply text-xl font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400 border-b-2 border-blue-500/10 pb-1 mt-8 mb-4;
  }

  .resume-content h3 {
    @apply text-lg font-bold text-slate-900 dark:text-white mt-5 mb-2;
  }

  /* Handle the job titles and bolding */
  .resume-content strong {
    @apply font-semibold text-slate-900 dark:text-white;
  }

  /* Style the dates/locations if they are italicized */
  .resume-content em {
    @apply text-sm text-slate-500 dark:text-slate-400 not-italic font-medium;
  }

  /* List and bullet points styling */
  .resume-content ul {
    @apply list-disc pl-5 space-y-1.5 my-3;
  }

  .resume-content li {
    @apply text-slate-600 dark:text-slate-300 text-sm leading-relaxed;
  }

  /* Style horizontal rules */
  .resume-content hr {
    @apply border-slate-200 dark:border-slate-800 my-8;
  }

  /* Style simple paragraphs */
  .resume-content p {
    @apply text-slate-600 dark:text-slate-300 text-sm my-2;
  }
</style>
