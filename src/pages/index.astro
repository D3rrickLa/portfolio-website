---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Contact from "../components/Contact.astro";
import Experience from "../components/Experience.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import AboutMe from "../components/AboutMe.astro";
---

<Layout>
  <Navbar />

  <main
    id="home"
    class="max-w-6xl mx-auto w-full px-6 min-h-screen flex flex-col justify-center items-center text-center pt-16"
  >
    <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight mb-4">
      Hi there, I'm <span class="text-brand-primary">Derrick La</span>!
    </h1>
    <p class="text-xl text-brand-muted mb-8 max-w-2xl mx-auto">
      Welcome to my lightning-fast Astro website hosted on GitHub Pages.
    </p>
    <a
      href="#projects"
      class="inline-block bg-brand-primary hover:bg-indigo-600 text-white font-semibold px-6 py-3 rounded-lg shadow-lg hover:shadow-indigo-500/20 transition-all duration-200"
    >
      View My Work
    </a>
  </main>

  <section
    id="about"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-h-[50vh] scroll-mt-16"
  >
    <h2 class="text-4xl font-bold mb-6">About Me</h2>
    <p class="text-brand-muted text-lg max-w-3xl leading-relaxed">
      Tell your story, skills, and background here. By limiting just this text
      width, it remains highly readable even though the section itself stretches
      wider across your monitor.
    </p>
    <AboutMe />
  </section>

  <section
    id="projects"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-h-screen scroll-mt-16"
  >
    <h2 class="text-4xl font-bold mb-8 text-right">Featured Projects</h2>
    <ProjectsGrid />
  </section>

  <section
    id="experience"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-h-screen scroll-mt-16"
  >
    <div class="text-center mb-16">
      <h2
        class="text-4xl font-extrabold text-zinc-100 tracking-tight mt-2 text-center"
      >
        Where I've Worked
      </h2>
      <p class="text-sm text-zinc-500 mt-2">
        From health startups to securing company data.
      </p>
    </div>
    <Experience />
  </section>

  <section
    id="contact"
    class="max-w-6xl mx-auto w-full px-6 py-24 scroll-mt-16"
  >
    <Contact />
  </section>
</Layout>
