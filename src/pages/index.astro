---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Contact from "../components/Contact.astro";
import Experience from "../components/Experience.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import AboutMe from "../components/AboutMe.astro";
---

<Layout>
  <Navbar />

  <main
    id="home"
    class="max-w-6xl mx-auto w-full px-6 min-h-screen flex flex-col justify-center items-center text-center pt-16"
  >
    <h1
      class="text-5xl sm:text-6xl font-extrabold tracking-tight mb-4 text-white"
    >
      Hi there, I'm <span
        class="bg-gradient-to-r from-fuchsia-400 via-purple-500 via-emerald-500 to-orange-400 bg-clip-text text-transparent bg-[length:200%_auto] animate-lava select-none inline-block"
        >Derrick La</span
      >
    </h1>
    <p class="text-xl text-brand-muted mb-8 max-w-2xl mx-auto">
      Welcome to my portfolio. Have a look around and feel free to contact me.
    </p>
    <a
      href="#projects"
      class="inline-block bg-brand-primary hover:bg-indigo-600 text-white font-semibold px-6 py-3 rounded-lg shadow-lg hover:shadow-indigo-500/20 transition-all duration-200"
    >
      View My Work
    </a>
  </main>

  <section
    id="about"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-h-[50vh] scroll-mt-16"
  >
    <AboutMe />
  </section>

  <section
    id="projects"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-screen scroll-mt-16"
  >
    <h2 class="text-4xl font-bold mb-8 text-center md:text-right">
      Featured <span
        class="bg-gradient-to-r from-fuchsia-400 via-purple-500 via-emerald-500 to-orange-400 bg-clip-text text-transparent bg-[length:200%_auto] animate-lava select-none"
        >Projects</span
      >
    </h2>
    <ProjectsGrid />
  </section>

  <section
    id="experience"
    class="max-w-6xl mx-auto w-full px-6 py-24 min-h-screen scroll-mt-16"
  >
    <div class="text-center mb-16">
      <h2
        class="text-4xl font-extrabold text-zinc-100 tracking-tight mt-2 text-center"
      >
        Where I've <span
          class="bg-gradient-to-r from-fuchsia-400 via-purple-500 via-emerald-500 to-orange-400 bg-clip-text text-transparent bg-[length:200%_auto] animate-lava select-none"
          >Worked</span
        >
      </h2>
      <p class="text-sm text-zinc-500 mt-2">
        From health startups to securing company data.
      </p>
    </div>
    <Experience />
  </section>

  <section
    id="contact"
    class="max-w-6xl mx-auto w-full px-6 py-24 scroll-mt-16"
  >
    <Contact />
  </section>
</Layout>

<style is:global>
  @keyframes lava-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-lava {
    animation: lava-shift 8s ease infinite;
  }
</style>
