---
interface ProjectProps {
    image: string;
    tag: string;
    title: string;
    description: string;
    startEndYear: string;
    techStack: string[];
    accentColor: string;
}

const projects: ProjectProps[] = [
    {
        image: "project_img/project_fortunelink_homepage.jpeg", //  Corrected path
        tag: "Web App",
        title: "FortuneLink",
        description:
            "Web Application meant to track and monitor one's personal finance for a better understanding on where their money is going.",
        startEndYear: "2025 - 2026",
        techStack: [
            "Spring Boot",
            "Java",
            "TypeScript",
            "Next.js",
            "Redis",
            "PostgreSQL",
        ],
        accentColor: "#FF5E00",
    },
    {
        image: "project_img/streamsage_profile.png",
        tag: "Audio Plugin",
        title: "Streamsage",
        description:
            "Full-stack mobile app with cloud server that gamifies personal development.",
        startEndYear: "2026",
        techStack: ["Java", "Spring Boot", "React"],
        accentColor: "#00A86B",
    },
    {
        image: "project_img/juceaudioplayerimage.png",
        tag: "Web App",
        title: "JUCE Audio Player",
        description:
            "A development tool to play audio, used for testing JUCE VST",
        startEndYear: "2024",
        techStack: ["C++", "JUCE", "DSP", "Audio"],
        accentColor: "#C127C1",
    },
    {
        image: "project_img/TinysHandsTalkImage.jpg",
        tag: "Web App",
        title: "TinyHandsTalk",
        description:
            "Full-stack web app for teaching parents baby sign language, with a custom-made machine learning model for interrupting sign language.",
        startEndYear: "2024",
        techStack: ["Python", "TensorFlow", "Angular"],
        accentColor: "#2327C1",
    },
];
---

<div class="max-w-7xl mx-auto w-full px-6 py-12 relative z-10">
    <!-- 1 col on mobile, 2 cols on tablet (md), 3 cols on desktop (lg) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            projects.map((project, index) => {
                const displayIndex = String(index + 1).padStart(2, "0");

                // Determine layout types based on the array position
                const isFirst = index === 0;
                const isSecond = index === 1;

                return (
                    <div
                        class={`border border-zinc-800 rounded-3xl overflow-hidden flex flex-col group transition-all duration-300 shadow-2xl bg-gradient-to-br from-zinc-950 via-zinc-950/90 to-[var(--project-accent)]/20
                            ${
                                isFirst
                                    ? "md:col-span-2 lg:col-span-3 lg:flex-row"
                                    : isSecond
                                      ? "md:col-span-2 lg:col-span-1"
                                      : ""
                            }`}
                        style={`--project-accent: ${project.accentColor};`}
                    >
                        {/* Project Image Box */}
                        <div
                            class={`bg-zinc-900 relative overflow-hidden border-zinc-800 
                                ${
                                    isFirst
                                        ? "h-64 lg:h-auto lg:w-[38%] flex-none border-b lg:border-b-0 lg:border-r"
                                        : isSecond
                                          ? "h-52 border-b md:h-64 md:lg:h-52"
                                          : "h-52 border-b"
                                }`}
                        >
                            <img
                                src={`${import.meta.env.BASE_URL}${project.image}`}
                                alt={project.title}
                                class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500 ease-out opacity-90"
                            />
                            <span class="absolute top-3 left-3 bg-zinc-900/80 backdrop-blur-md text-zinc-300 text-xs font-mono tracking-wider px-2.5 py-1 rounded-full border border-zinc-800 uppercase">
                                {project.tag}
                            </span>
                        </div>

                        {/* Project Details Box */}
                        <div
                            class={`flex flex-col flex-grow justify-between 
                                ${isFirst ? "lg:p-8 p-6" : "py-12 px-6"}`}
                        >
                            <div>
                                <div class="flex justify-between items-start mb-3 gap-4">
                                    <h3 class="text-xl font-bold tracking-wide uppercase flex items-baseline gap-2 text-white">
                                        <span class="text-zinc-500 font-mono text-lg font-medium">
                                            {displayIndex}
                                        </span>
                                        <span>{project.title}</span>
                                    </h3>

                                    <div class="flex items-center gap-2">
                                        <span class="text-xs text-zinc-500 font-mono tracking-wider whitespace-nowrap">
                                            {project.startEndYear}
                                        </span>
                                        {/* External link icon shows on large screens only for the absolute first featured project */}
                                        {isFirst && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="text-zinc-400 group-hover:text-white transition-colors hidden lg:block"
                                            >
                                                <path d="M15 3h6v6" />
                                                <path d="M10 14 21 3" />
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                            </svg>
                                        )}
                                    </div>
                                </div>

                                <p class="text-sm text-zinc-400 leading-relaxed mb-6">
                                    {project.description}
                                </p>
                            </div>

                            {/* Tech Stack Tags */}
                            <div class="flex flex-wrap gap-2 mt-auto">
                                {project.techStack.map((tech) => (
                                    <span class="bg-zinc-900/60 border border-[var(--project-accent)]/20 text-xs text-zinc-300 px-3 py-1 rounded-xl font-medium tracking-wide">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                );
            })
        }
    </div>

    {/* GitHub Explore CTA with sliding external-link icon */}
    <div class="flex justify-center mt-20 pt-10 border-t border-white/5">
        <a
            href="https://github.com/D3rrickLa?tab=repositories"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 sm:gap-3 text-sm sm:text-xl font-semibold text-accent hover:text-accent-hover transition-colors text-center text-pretty"
        >
            <span>Explore all projects on GitHub</span>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-external-link group-hover:translate-x-1.5 group-hover:-translate-y-1.5 transition-transform duration-300"
                aria-hidden="true"
            >
                <path d="M15 3h6v6"></path>
                <path d="M10 14 21 3"></path>
                <path
                    d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                ></path>
            </svg>
        </a>
    </div>
</div>
