---
const profile = {
  name: {
    first: "Derrick",
    last: "La",
  },
  role: "Systems & Security-Minded Infrastructure Engineer",

  deck: {
    left: {
      title: "SecOps & Defense",
      desc: "Managed 50+ CrowdStrike & ReliaQuest enterprise alerts at PointClickCare. Governed cloud environments by auditing and tagging 1,000+ apps in Defender for Cloud Apps.",
    },
    center: {
      title: "My Framework",
      desc: "Bridging York CS and Sheridan Systems Tech. I don't just follow operational playbooks, I write the code and build the automation frameworks that replace them.",
    },
    right: {
      title: "Automation & Tools",
      desc: "Engineered Python/Pandas tooling that slashed manual audit times by 97%. Accelerated QA cycles by automating critical verification pipelines via Selenium.",
    },
  },

  mindset: {
    title: "Mindset",
    highlight: "Systems should evolve, not repeat.",
    body: "I work best when given complex system problems and the autonomy to design the architecture. Success isn't merely completing a routine task, but engineering a permanent, automated solution that makes infrastructure inherently resilient.",
    images: [
      {
        src: "https://images.unsplash.com/photo-1618401471353-b98afee0b2eb?q=80&w=3000&auto=format&fit=crop",
        alt: "Clean terminal layout with custom automation scripts",
        badge: "Python & Automation",
      },
      {
        src: "https://images.unsplash.com/photo-1600132806370-bf17e65e942f?q=80&w=3000&auto=format&fit=crop",
        alt: "Server configuration and systems dashboard",
        badge: "Cloud Infrastructure",
      },
      {
        src: "https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=3000&auto=format&fit=crop",
        alt: "Security monitoring tools displaying telemetry",
        badge: "SecOps & Governance",
      },
    ],
    footer: "System friction is the enemy. Engineered automation is the solution.",
  },

  avatar: {
    src: "/other_img/profile.jpg",
    alt: "Derrick La Portrait",
    location: "Toronto, Canada",
    coordinates: "43.6532° N, 79.3832° W",
    timezone: "EST",
  },

  craft: {
    title: "Craft",
    highlight: "Translating architectural designs into production-grade deployments.",
    advice: "With a foundation in Computer Systems Technology and deeper training from a Computer Science degree, I combine systems knowledge with software design to build clean backends, secure cloud pipelines, and automated test suites.",
    techStack: [
      { name: "Python", slug: "python" },
      { name: "Git", slug: "git" },
      { name: "Bash", slug: "bash" },
      { name: "Linux", slug: "linux" },
      { name: "Docker", slug: "docker" },
      { name: "Terraform", slug: "terraform" },
      { name: "TypeScript", slug: "typescript" },
      { name: "Node.js", slug: "nodejs" },
      { name: "Spring Boot", slug: "spring" },
      { name: "PostgreSQL", slug: "postgresql" },
      { name: "TensorFlow", slug: "tensorflow" },
      { name: "Java", slug: "java" },
    ],
    footer: "Building with an emphasis on visibility, scale, and ironclad security.",
    statusText: "Open to Systems, SecOps, & DevOps roles",
  },
};
---

<div
  class="max-w-6xl mx-auto px-6 py-12 text-white font-sans selection:bg-fuchsia-500/30"
>
  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 auto-rows-[minmax(110px,_auto)]"
  >
    <!-- Name and Title Block -->
    <div
      class="bg-gradient-to-b from-zinc-900 to-zinc-950/40 border border-zinc-800/80 rounded-3xl p-5 lg:col-span-1 flex flex-col justify-center items-center text-center group hover:border-fuchsia-500/50 transition-all duration-300 shadow-[0_0_20px_rgba(0,0,0,0.8)]"
    >
      <h1
        class="text-4xl font-extrabold tracking-wider uppercase filter drop-shadow-[0_0_20px_rgba(197,224,227,0.35)]"
      >
        <span class="text-white drop-shadow-[0_0_8px_rgba(211,236,240,0.4)]">{profile.name.first}</span>
        <span class="text-zinc-400 font-medium drop-shadow-[0_0_8px_rgba(211,236,240,0.4)]">{profile.name.last}</span>
      </h1>
      <p
        class="text-[12px] text-zinc-500 font-mono tracking-widest uppercase mt-1"
      >
        {profile.role}
      </p>
    </div>

    <!-- Three Cards Block -->
    <div
      class="relative bg-zinc-900 border border-zinc-800/80 rounded-3xl p-5 lg:col-span-2 flex flex-col justify-end group/container hover:border-purple-500/50 transition-all duration-300 overflow-hidden shadow-[0_0_20px_rgba(0,0,0,0.8)]"
    >
      <span
        class="hidden lg:inline-block lg:absolute top-3 right-5 text-[9px] font-bold text-fuchsia-400/80 font-mono tracking-widest uppercase pointer-events-none transition-opacity duration-300 group-hover/container:opacity-0 z-40"
      >
        Hover to read more
      </span>

      <div class="relative w-full flex flex-col items-center justify-center min-h-[220px] lg:min-h-0 lg:h-28">
        <div class="grid grid-cols-1 md:grid-cols-3 lg:block relative w-full max-w-md lg:max-w-none">
          <div class="bg-zinc-950/90 p-4 rounded-xl border border-zinc-800/80 shadow-md transition-all duration-300 ease-out cursor-pointer mb-3 md:mb-0 group/card relative lg:absolute lg:top-1 lg:left-[5%] lg:w-56 lg:h-24 lg:opacity-60 lg:-rotate-6 lg:z-10 hover:lg:h-40 hover:lg:opacity-100 hover:lg:-translate-y-[60px] hover:lg:-rotate-2 hover:lg:z-30 hover:lg:border-orange-500/60 hover:shadow-[0_0_30px_-5px_rgba(245,158,11,0.4),0_20px_25px_-5px_rgba(0,0,0,0.7)]">
            <div class="relative z-10">
              <h4 class="text-xs font-bold font-mono text-zinc-400 uppercase transition-colors group-hover/card:text-amber-400">
                {profile.deck.left.title}
              </h4>
              <p class="text-[11px] text-zinc-500 leading-normal mt-2 opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 delay-75 hidden lg:block">
                {profile.deck.left.desc}
              </p>
              <p class="text-[11px] text-zinc-500 leading-normal mt-1 lg:hidden">
                {profile.deck.left.desc}
              </p>
            </div>
          </div>

          <div class="bg-zinc-950 p-4 rounded-xl border border-zinc-700/60 shadow-2xl transition-all duration-300 ease-out cursor-pointer mb-3 md:mb-0 group/card
                      lg:absolute lg:top-0 lg:left-1/2 lg:-translate-x-1/2 lg:w-56 lg:h-24 lg:z-20
                      hover:lg:h-40 hover:lg:-translate-y-[60px] hover:lg:scale-102 hover:lg:z-30 hover:lg:border-purple-500/60
                      hover:shadow-[0_0_30px_-5px_rgba(168,85,247,0.4),0_20px_25px_-5px_rgba(0,0,0,0.7)]">
            <h4 class="text-xs font-bold font-mono text-white uppercase text-center transition-colors group-hover/card:text-purple-400">
              {profile.deck.center.title}
            </h4>
            <p class="text-[11px] text-zinc-400 leading-normal mt-2 text-center opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 delay-75 hidden lg:block">
              {profile.deck.center.desc}
            </p>
            <p class="text-[11px] text-zinc-400 leading-normal mt-1 text-center lg:hidden">
              {profile.deck.center.desc}
            </p>
          </div>

          <div class="bg-zinc-950/90 p-4 rounded-xl border border-zinc-800/80 shadow-md transition-all duration-300 ease-out cursor-pointer group/card
                      lg:absolute lg:top-1 lg:right-[5%] lg:w-56 lg:h-24 lg:opacity-60 lg:rotate-6 lg:z-10
                      hover:lg:h-40 hover:lg:opacity-100 hover:lg:-translate-y-[60px] hover:lg:rotate-2 hover:lg:z-30 hover:lg:border-cyan-500/50
                      hover:shadow-[0_0_30px_-5px_rgba(6,182,212,0.4),0_20px_25px_-5px_rgba(0,0,0,0.7)]">
            <h4 class="text-xs text-right font-bold font-mono text-zinc-400 uppercase transition-colors group-hover/card:text-cyan-400">
              {profile.deck.right.title}
            </h4>
            <p class="text-[11px] text-zinc-500 leading-normal mt-2 text-right opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 delay-75 hidden lg:block">
              {profile.deck.right.desc}
            </p>
            <p class="text-[11px] text-zinc-500 leading-normal mt-1 text-right lg:hidden">
              {profile.deck.right.desc}
            </p>
          </div>

        </div>
      </div>
    </div>

    <div
      class="bg-zinc-900 border border-zinc-800/80 rounded-3xl p-8 flex flex-col justify-between lg:row-span-3 group hover:border-fuchsia-500/40 transition-all duration-300 shadow-[0_0_20px_rgba(0,0,0,0.8)]"
    >
      <div>
        <h2
          class="text-3xl font-bold tracking-tight text-white mb-2 relative inline-block"
        >
          {profile.mindset.title}
          <span
            class="absolute bottom-[-4px] left-0 w-8 h-[3px] bg-gradient-to-r from-fuchsia-500 to-purple-500 rounded transition-opacity duration-300 group-hover:opacity-0"
          ></span>
        </h2>
        <p class="text-zinc-400 text-sm leading-relaxed mt-4">
          <strong class="text-zinc-200">{profile.mindset.highlight}</strong>
          {profile.mindset.body}
        </p>
      </div>

      <!-- Interactive 3D Spread Deck Wrapper -->
      <div
        class="mindset-carousel my-6 relative h-50 w-full z-10 group/carousel"
        style="perspective: 1200px;"
      >
        <!-- Stacked Spread Container -->
        <div class="deck-container w-full h-full relative flex items-center justify-center">
          {
            profile.mindset.images.map((img, index) => (
              <div
                class="deck-card absolute w-[70%] h-[85%] rounded-xl overflow-hidden shadow-2xl border border-zinc-800/80"
                data-index={index}
              >
                <!-- Subtle Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent z-10 select-none pointer-events-none" />
                
                <!-- Slide Image -->
                <img
                  src={img.src}
                  alt={img.alt}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 card-img"
                  style="opacity: 0.75;"
                />
                
                <!-- Badge Content -->
                <div class="carousel-content absolute bottom-4 left-4 z-20 transition-opacity duration-300">
                  <span class="text-xs font-mono uppercase font-bold text-fuchsia-300 tracking-wider drop-shadow-[0_2px_4px_rgba(0,0,0,0.9)]">
                    {img.badge}
                  </span>
                </div>
              </div>
            ))
          }
        </div>

      <!-- Tiny Navigation Dots -->
      <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-40 flex gap-1.5">
        {
          profile.mindset.images.map((_, index) => (
            <button
              class="carousel-dot w-1.5 h-1.5 rounded-full transition-all duration-300 bg-zinc-600"
              aria-label={`Go to card ${index + 1}`}
              data-index={index}
            />
          ))
        }
      </div>
    </div>

    <p class="text-sm text-zinc-400">
      {profile.mindset.footer}
    </p>
  </div>

    <!-- Avatar Block -->
    <div
      class="bg-zinc-900 border border-zinc-800/80 rounded-3xl overflow-hidden lg:row-span-3 flex flex-col justify-between group hover:border-purple-500/40 transition-all duration-300 h-[450px] lg:h-auto shadow-[0_0_20px_rgba(0,0,0,0.8)]"
    >
      <div class="w-full flex-1 bg-zinc-950 relative overflow-hidden">
        <img
          src={profile.avatar.src}
          alt={profile.avatar.alt}
          class="absolute md:object-[42%_100%] inset-0 w-full h-full object-cover opacity-80 transition-transform duration-500 ease-out group-hover:scale-105 backface-hidden will-change-transform"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-90 z-10"
        >
        </div>
      </div>

      <div
        class="bg-zinc-950/80 p-6 overflow-hidden relative flex flex-col justify-end border-t border-zinc-800/30"
      >
        <div
          class="absolute inset-0 opacity-5 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px]"
        >
        </div>

        <div class="relative z-10">
          <h3
            class="text-xl font-black bg-gradient-to-r from-zinc-100 to-zinc-400 bg-clip-text text-transparent tracking-tight uppercase"
          >
            {profile.avatar.location}
          </h3>
          <div
            class="flex justify-between items-center text-[10px] font-mono text-zinc-500 tracking-widest mt-1"
          >
            <span>{profile.avatar.coordinates}</span>
            <span class="text-cyan-400 font-bold"
              >- {profile.avatar.timezone}</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Craft Block -->
    <div
      class="bg-zinc-900 border border-zinc-800/80 rounded-3xl p-8 flex flex-col justify-between lg:row-span-3 group hover:border-cyan-500/40 transition-all duration-300 shadow-[0_0_20px_rgba(0,0,0,0.8)]"
    >
      <div>
        <h2
          class="text-3xl font-bold tracking-tight text-white mb-2 relative inline-block"
        >
          {profile.craft.title}
          <span
            class="absolute bottom-[-4px] left-0 w-8 h-[3px] bg-gradient-to-r from-cyan-500 to-purple-500 rounded transition-opacity duration-300 group-hover:opacity-0"
          ></span>
        </h2>
        <p class="text-zinc-100 text-sm leading-relaxed mt-4">
          <strong>{profile.craft.highlight}</strong>
        </p>
        <p class="text-zinc-400 text-sm leading-relaxed mt-3">
          {profile.craft.advice}
        </p>
      </div>

      <div
        class="relative w-full overflow-hidden my-4 py-3 border-y border-zinc-800/60 flex gap-4"
      >
        <div
          class="absolute inset-y-0 left-0 w-8 bg-gradient-to-r from-zinc-900 to-transparent z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-zinc-900 to-transparent z-10 pointer-events-none"
        >
        </div>

        <div class="flex gap-4 flex-none min-w-full justify-around animate-marquee text-xs md:text-sm text-white font-mono uppercase font-semibold">
          {
            profile.craft.techStack.map((tech) => (
              <span class="bg-zinc-950 px-4 py-2.5 rounded-md border border-zinc-800/80 shadow-sm shadow-purple-500/5 flex items-center gap-2.5 stabilization">
                <img
                  src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.slug}/${tech.slug}-original.svg`}
                  alt={`${tech.name} logo`}
                  class="w-5 h-5 object-contain tracking-normal"
                  loading="lazy"
                />
                {tech.name}
              </span>
            ))
          }
        </div>

        <div class="flex gap-4 flex-none min-w-full justify-around animate-marquee text-xs md:text-sm text-white font-mono uppercase font-semibold" aria-hidden="true">
          {
            profile.craft.techStack.map((tech) => (
              <span class="bg-zinc-950 px-4 py-2.5 rounded-md border border-zinc-800/80 shadow-sm shadow-purple-500/5 flex items-center gap-2.5 stabilization">
                <img
                  src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.slug}/${tech.slug}-original.svg`}
                  alt={`${tech.name} logo`}
                  class="w-5 h-5 object-contain tracking-normal"
                  loading="lazy"
                />
                {tech.name}
              </span>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-xs text-zinc-400 leading-relaxed mb-4">
          {profile.craft.footer}
        </p>
        <div class="flex items-center gap-2 text-xs font-medium text-emerald-400">
          <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_#56D677] animate-pulse"></span>
          {profile.craft.statusText}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Base transitions across layouts */
  .deck-card {
    transition: transform 0.65s cubic-bezier(0.25, 1, 0.5, 1),
                opacity 0.65s ease,
                filter 0.65s ease,
                box-shadow 0.65s ease;
    transform-style: preserve-3d;
    cursor: pointer;
  }

  /* Core Active Frame (Top Deck) */
  .deck-card.layer-center {
    transform: translate3d(0, 0, 10px) scale(1) rotateY(0deg);
    opacity: 1;
    z-index: 30;
    filter: brightness(1.05);
    box-shadow: 0 0 30px -5px rgba(217, 70, 239, 0.35), 0 20px 25px -5px rgba(0, 0, 0, 0.7);
    pointer-events: auto;
  }
  .deck-card.layer-center:hover .card-img {
    transform: scale(1.03);
  }

  /* Left Peeking Card Layer */
  .deck-card.layer-left {
    transform: translate3d(-35%, 0, -60px) scale(0.9) rotateY(22deg);
    opacity: 0.45;
    z-index: 20;
    filter: brightness(0.4) blur(0.5px);
    pointer-events: auto;
  }
  .deck-card.layer-left .carousel-content {
    opacity: 0;
  }

  /* Right Peeking Card Layer */
  .deck-card.layer-right {
    transform: translate3d(35%, 0, -60px) scale(0.9) rotateY(-22deg);
    opacity: 0.45;
    z-index: 20;
    filter: brightness(0.4) blur(0.5px);
    pointer-events: auto;
  }
  .deck-card.layer-right .carousel-content {
    opacity: 0;
  }

  /* Hidden Fallback Stack Cards */
  .deck-card.layer-hidden {
    transform: translate3d(0, 0, -140px) scale(0.75);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* Layout Marquee Styles */
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% - 1rem)); }
  }
  .animate-marquee {
    animation: marquee 45s linear infinite;
  }
</style>

<script>
  function initMindsetSpreadDeck() {
    const carousels = document.querySelectorAll(".mindset-carousel");

    carousels.forEach((carousel) => {
      const cards = Array.from(carousel.querySelectorAll(".deck-card")) as HTMLElement[];
      const dots = carousel.querySelectorAll(".carousel-dot");

      if (cards.length === 0) return;

      let currentIdx = 0;
      const totalCards = cards.length;
      let autoplayTimer: number | null = null;

      function render() {
        const prevIdx = (currentIdx - 1 + totalCards) % totalCards;
        const nextIdx = (currentIdx + 1) % totalCards;

        cards.forEach((card, idx) => {
          card.classList.remove("layer-center", "layer-left", "layer-right", "layer-hidden");

          if (idx === currentIdx) {
            card.classList.add("layer-center");
          } else if (idx === prevIdx) {
            card.classList.add("layer-left");
          } else if (idx === nextIdx) {
            card.classList.add("layer-right");
          } else {
            card.classList.add("layer-hidden");
          }
        });

        // Sync indicators
        dots.forEach((dot, idx) => {
          if (idx === currentIdx) {
            dot.className = "carousel-dot h-1.5 rounded-full transition-all duration-300 bg-fuchsia-500 w-3.5";
          } else {
            dot.className = "carousel-dot w-1.5 h-1.5 rounded-full transition-all duration-300 bg-zinc-600";
          }
        });
      }

      function navigate(direction: number) {
        currentIdx = (currentIdx + direction + totalCards) % totalCards;
        render();
      }

      // Explicit Card Interactions (Clicking Peeking Sides)
      cards.forEach((card) => {
        card.addEventListener("click", (e) => {
          if (card.classList.contains("layer-left")) {
            navigate(-1);
          } else if (card.classList.contains("layer-right") || card.classList.contains("layer-center")) {
            navigate(1);
          }
        });
      });

      dots.forEach((dot, idx) => {
        dot.addEventListener("click", (e) => {
          e.preventDefault();
          currentIdx = idx;
          render();
        });
      });

      // Autoplay cycle handling
      function startAutoplay() {
        if (!autoplayTimer) {
          autoplayTimer = window.setInterval(() => navigate(1), 5500);
        }
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      carousel.addEventListener("mouseenter", stopAutoplay);
      carousel.addEventListener("mouseleave", startAutoplay);

      // Mobile Swipe Handling
      let touchStartX = 0;
      let touchEndX = 0;

      carousel.addEventListener("touchstart", (e: any) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      carousel.addEventListener("touchend", (e: any) => {
        touchEndX = e.changedTouches[0].screenX;
        const delta = touchStartX - touchEndX;
        if (Math.abs(delta) > 40) {
          navigate(delta > 0 ? 1 : -1);
        }
      }, { passive: true });

      render();
      startAutoplay();
    });
  }

  document.addEventListener("DOMContentLoaded", initMindsetSpreadDeck);
  document.addEventListener("astro:after-swap", initMindsetSpreadDeck);
</script>