---
// src/components/Navbar.astro
interface NavItem {
  label: string;
  href: string;
}

// If it's the GitHub link, open it in a new tab; otherwise, keep it local
const navItems: NavItem[] = [
  { label: "About", href: "#about" },
  { label: "Projects", href: "#projects" },
  { label: "Experience", href: "#experience" },
  { label: "Contact", href: "#contact" },
  { label: "Github", href: "https://github.com/D3rrickla" },
];
---

<nav
  class="bg-brand-surface/80 backdrop-blur-md border-b border-brand-muted/20 px-6 py-4 sticky top-0 z-50 h-16 flex items-center"
>
  <div
    class="max-w-6xl mx-auto w-full flex justify-between items-center relative"
  >
    <a
      href="#home"
      class="text-xl font-bold text-brand-text tracking-tight hover:text-brand-primary transition-colors"
    >
      Derrick<span class="text-brand-primary"> La</span>
    </a>

    <!-- CSS Toggle Trigger using a hidden checkbox -->
    <input type="checkbox" id="menu-toggle" class="peer hidden" />

    <!-- Hamburger Menu Button (visible only on mobile) -->
    <label
      for="menu-toggle"
      class="md:hidden cursor-pointer p-2 z-50 text-brand-text hover:text-brand-primary transition-colors"
      aria-label="Toggle Menu"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </label>

    <!-- Nav Items Links -->
    <!-- Responds to the checkbox state using Tailwind's peer-checked variants -->
    <div
      class="absolute top-14 left-0 right-0 hidden peer-checked:flex flex-col bg-brand-surface/95 border border-brand-muted/20 rounded-2xl p-6 gap-4 shadow-xl backdrop-blur-md
                    md:relative md:top-0 md:flex md:flex-row md:bg-transparent md:border-none md:p-0 md:gap-6 md:shadow-none md:w-auto"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={
              item.href.startsWith("http") ? "noopener noreferrer" : undefined
            }
            class="nav-link text-brand-muted font-medium hover:text-brand-text transition-all relative py-1 text-base md:text-sm"
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<style>
  .nav-link::after {
    content: "";
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 0;
    background-color: var(--color-brand-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>
